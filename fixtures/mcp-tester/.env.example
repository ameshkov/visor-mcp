# --- Vision MCP server settings (forwarded to the spawned server) ---

# OpenAI-compatible API key. Required.
VISION_MCP_API_KEY=

# Provider base URL (http or https). Required.
# Example: https://api.openai.com/v1
VISION_MCP_BASE_URL=https://api.openai.com/v1

# Model name. Required.
VISION_MCP_MODEL=gpt-4o

# Optional knobs (defaults shown).
VISION_MCP_MAX_IMAGE_SIZE_MB=5
VISION_MCP_REQUEST_TIMEOUT_MS=60000
# VISION_MCP_REQUEST_BODY_JSON={"temperature":0}

# --- Tester settings ---

# How to launch the vision-mcp server. Defaults run the parent repo build:
# command=node, args=build/index.js, cwd=<vision-mcp repo root>.
# MCP_TESTER_SERVER_COMMAND=node
# MCP_TESTER_SERVER_ARGS=build/index.js
# MCP_TESTER_SERVER_CWD=/absolute/path/to/vision-mcp

# Fixture directory (absolute, or relative to the tester root).
# MCP_TESTER_FIXTURES_DIR=./cases

# Set to 1 to also run cases that make real provider calls.
# MCP_TESTER_LIVE=0
